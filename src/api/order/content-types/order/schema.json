{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "orderNumber": {
      "type": "string"
    },
    "state": {
      "type": "enumeration",
      "default": "Pending",
      "enum": [
        "Pending",
        "Paid",
        "Processing",
        "Shipped",
        "Completed",
        "Cancelled"
      ]
    },
    "users_permissions_user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "order"
    },
    "order_item": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::order-item.order-item",
      "mappedBy": "order"
    }
  }
}
